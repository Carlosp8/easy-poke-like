{
  "name": "easy-pokelike",
  "version": "9.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "extract:bundle": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/extract-pokelike-bundle.ts",
    "build": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/build-userscript.ts && node --check easy-pokelike.user.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --disable-warning=ExperimentalWarning --experimental-strip-types --test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1"
  }
}
